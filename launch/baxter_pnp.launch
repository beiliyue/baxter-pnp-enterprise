<launch>
  <!--
  Baxter PnP Enterprise Launch File
  ==================================
  用法:
    roslaunch baxter_pnp_enterprise baxter_pnp.launch
    
  单机模式（Baxter真机）:
    roslaunch baxter_pnp_enterprise baxter_pnp.launch \
      limb:=right \
      force_threshold:=-8.0

  rosbag录制:
    roslaunch baxter_pnp_enterprise baxter_pnp.launch record:=true
  -->

  <!-- ── Arguments ──────────────────────────────────────────────────── -->
  <arg name="limb"             default="right"/>
  <arg name="force_threshold"  default="-8.0"/>
  <arg name="hover_distance"   default="0.12"/>
  <arg name="step_size"        default="0.05"/>
  <arg name="place_x"          default="0.7"/>
  <arg name="place_y"          default="-0.5"/>
  <arg name="place_z"          default="-0.2"/>
  <arg name="spinner_threads"  default="4"/>
  <arg name="record"           default="false"/>
  <arg name="bt_xml"           default="$(find baxter_pnp_enterprise)/bt_xml/baxter_pnp_bt.xml"/>
  <arg name="sim"              default="false"/>
  <arg name="run_perception"   default="true"/>
  <arg name="model_path"       default="$(find baxter_pnp_enterprise)/models/grconvnet.pt"/>

  <!-- ── PnP Main Node ──────────────────────────────────────────────── -->
  <node name="baxter_pnp_main" pkg="baxter_pnp_enterprise" type="pnp_main"
        output="screen" required="true">

    <!-- Parameters (override via command line: _param:=value) -->
    <param name="limb"            value="$(arg limb)"/>
    <param name="force_threshold" value="$(arg force_threshold)"/>
    <param name="hover_distance"  value="$(arg hover_distance)"/>
    <param name="step_size"       value="$(arg step_size)"/>
    <param name="place_x"         value="$(arg place_x)"/>
    <param name="place_y"         value="$(arg place_y)"/>
    <param name="place_z"         value="$(arg place_z)"/>
    <param name="spinner_threads" value="$(arg spinner_threads)"/>
    <param name="bt_xml"          value="$(arg bt_xml)"/>

    <!-- Remap topics for Baxter robot -->
    <remap from="/robot/joint_states"
           to="/robot/joint_states"/>
    <remap from="/robot/limb/right/joint_command"
           to="/robot/limb/right/joint_command"/>
    <remap from="/robot/end_effector/right/gripper_command"
           to="/robot/end_effector/right/gripper_command"/>

  </node>

  <!-- ── Perception Node (独立进程 — 深度学习推理) ────────────── -->
  <!--
  进程隔离: perception_node 是一个独立ROS进程。
  如果深度学习模型崩溃（OOM/段错误），不会影响 pnp_main 的运动控制。
  Baxter 停在安全位置，不会伤人。
  
  通信方式（替代原始numpy IPC）:
    perception_node  → pub /baxter_pnp/grasp_pose  (PoseStamped)
    perception_node  ← sub /baxter_pnp/grasp_request (Bool)
    perception_node  ← sub /camera/rgb/image_raw    (Image, BEST_EFFORT)
  
  原始Python代码 (pnp.py:93-99) 使用numpy文件:
    np.save(grasp_request, 1)       → 现在: pub /baxter_pnp/grasp_request
    while not np.load(grasp_avail)  → 现在: DetectObject订阅 /baxter_pnp/grasp_pose
    grasp_pose = np.load(grasp_pose) → 现在: topic消息直接写入Blackboard
  -->
  <group if="$(arg run_perception)">
    <node name="baxter_perception" pkg="baxter_pnp_enterprise" type="perception_node"
          output="screen" required="false">  <!-- required=false: 感知崩溃不影响主控制 -->
      <param name="model_path"  value="$(arg model_path)"/>
      <param name="image_topic" value="/camera/rgb/image_raw"/>
      <param name="grasp_pub_topic" value="/baxter_pnp/grasp_pose"/>
    </node>
  </group>

  <!-- ── Nodelet: 零拷贝相机传输 (可选) ────────────────────────── -->
  <!--
  在 pnp_main 进程内加载 camera_nodelet，图像数据零拷贝。
  但牺牲了进程隔离性 —— camera_nodelet 崩溃会带走 pnp_main。
  
  取消注释以启用:
  <node name="camera_nodelet_manager" pkg="nodelet" type="nodelet"
        args="manager" output="screen"/>
  <node name="camera_nodelet" pkg="nodelet" type="nodelet"
        args="load baxter_pnp_enterprise/baxter_pnp/CameraNodelet camera_nodelet_manager"
        output="screen"/>
  -->

  <!-- ── rosbag Recording (for offline fault analysis) ────────────── -->
  <!--
  录制所有关键topic，包括：
    - /robot/joint_states    关节状态
    - /robot/joint_command   控制命令
    - /rosout                日志（包含PNP_EVENT标记）
    - /diagnostics           诊断信息
    - /tf                    坐标变换
  
  故障分析:
    rosbag play recorded.bag /rosout:=/rosout_replay
    rostopic echo /rosout_replay | grep PNP_EVENT
    rostopic echo /rosout_replay | grep GraspFailure
  -->
  <group if="$(arg record)">
    <node name="rosbag_record" pkg="rosbag" type="record"
          args="record -a -o $(env HOME)/baxter_pnp_bags/">
      <remap from="/rosout" to="/rosout"/>
    </node>
  </group>

  <!-- ── Diagnostics ───────────────────────────────────────────────── -->
  <node name="diagnostics_aggregator"
        pkg="diagnostic_aggregator" type="diagnostic_aggregator"
        output="screen"/>

  <!-- ── RViz (for visualization) ──────────────────────────────────── -->
  <node name="rviz" pkg="rviz" type="rviz"
        args="-d $(find baxter_pnp_enterprise)/config/baxter_pnp.rviz"
        if="$(arg sim)"/>

</launch>
